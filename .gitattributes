# Ensure proper line endings and encoding
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.txt text eol=lf

# Ensure UTF-8 encoding for text files
*.ts charset=utf-8
*.tsx charset=utf-8
*.js charset=utf-8
*.jsx charset=utf-8
*.json charset=utf-8
*.md charset=utf-8
*.html charset=utf-8
*.css charset=utf-8
*.txt charset=utf-8