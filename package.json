  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "build:desktop": "vite build && electron-builder",
    "build:desktop:win": "vite build && electron-builder --win",
    "build:desktop:mac": "vite build && electron-builder --mac",
    "build:desktop:publish:win": "vite build && electron-builder --win --publish always",
    "build:desktop:publish:mac": "vite build && electron-builder --mac --publish always",
    "build:dev": "vite build --mode development",
    "build:analyze": "vite build --mode production && npx vite-bundle-analyzer dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "preflight:desktop-release": "node scripts/desktop-release-preflight.cjs",
    "verify:desktop-release": "node scripts/verify-desktop-release.cjs",
    "seed": "ts-node --esm backend/prisma/seed.ts",
    "seed:test": "ts-node --esm backend/prisma/seed-test.ts"
