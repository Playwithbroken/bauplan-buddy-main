const queryClient = new QueryClient();

declare global {
  interface Window {
    __bauplanServicesInitialized?: boolean;
  }
}

// Initialize all services
const initializeServices = () => {
  try {
    console.log("App: Initializing services...");

    // Initialize services by accessing their getInstance methods
    try {
      ThemeService.getInstance();
      console.log("App: ThemeService initialized");
    } catch (error) {
      console.warn("App: ThemeService initialization failed:", error);
    }

    try {
      KeyboardShortcutService.getInstance();
      console.log("App: KeyboardShortcutService initialized");
    } catch (error) {
      console.warn(
        "App: KeyboardShortcutService initialization failed:",
        error
      );
    }

    try {
      MobileUIService.getInstance();
      console.log("App: MobileUIService initialized");
    } catch (error) {
      console.warn("App: MobileUIService initialization failed:", error);
    }

    try {
      AccessibilityService.getInstance();
      console.log("App: AccessibilityService initialized");
    } catch (error) {
      console.warn("App: AccessibilityService initialization failed:", error);
    }

    try {
      // Performance optimization service is already a singleton instance
      performanceOptimizationService.analyzeBundleSize();
      console.log("App: PerformanceOptimizationService initialized");
    } catch (error) {
      console.warn(
        "App: PerformanceOptimizationService initialization failed:",
        error
      );
    }

    try {
      // Initialize route preloading
      initializePreloading();
      console.log("App: Route preloading initialized");
    } catch (error) {
        </ThemeProvider>
      </BrowserRouter>
    </QueryClientProvider>
  );
};

export default App;
